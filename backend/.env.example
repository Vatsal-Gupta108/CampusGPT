# API Configuration
PROJECT_NAME="AI Knowledge Assistant"
API_V1_STR="/api/v1"

# Security
# WARNING: Keep this secret in production!
SECRET_KEY="super_secret_key_for_development_change_in_production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# Using SQLite for easy local development. For production, change to Postgres:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost/dbname"
DATABASE_URL="sqlite:///./sql_app.db"

# LLM Configuration
# We support either "local" or "openai" or "gemini"
LLM_PROVIDER="local"
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# Vector Store
CHROMA_PERSIST_DIRECTORY="./chroma_db"
